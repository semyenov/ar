## Vue Component Structure

```vue
<script setup lang="ts">
// Imports
import { ref, computed } from 'vue'
import { Button } from '@/components/ui/button'

// Types
interface Props {
  title: string
  variant?: 'default' | 'outline'
}

// Props with TS interface
const props = defineProps<Props>()

// Emits with TS declarations
const emit = defineEmits<{
  (e: 'update', value: string): void
  (e: 'delete'): void
}>()

// Reactive state
const isOpen = ref(false)

// Computed properties
const computedValue = computed(() => {
  return props.title.toUpperCase()
})

// Methods
function handleClick() {
  isOpen.value = !isOpen.value
  emit('update', computedValue.value)
}
</script>

<template>
  <div class="component-container">
    <h2 class="text-xl font-semibold">{{ computedValue }}</h2>
    <Button @click="handleClick" :variant="variant">
      Toggle
    </Button>
  </div>
</template>
```

## TypeScript Usage

1. **Type Definitions**

```typescript
// Explicit typing for variables
const count = ref<number>(0)

// Interface for objects
interface User {
  id: string
  name: string
  email: string
  role: UserRole
}

// Type for function parameters and returns
function formatUserName(user: User): string {
  return `${user.name} <${user.email}>`
}

// Enums for finite sets of values
enum UserRole {
  Admin = 'admin',
  User = 'user',
}

// Union types for variants
type ButtonVariant = 'default' | 'primary' | 'secondary' | 'danger'
```

2. **Generic Types**

```typescript
// Generic function
function pickRandomItem<T>(items: T[]): T {
  return items[Math.floor(Math.random() * items.length)]
}

// Generic components (in .vue files)
const emit = defineEmits<{
  (e: 'select', item: T): void
}>()
```

## Error Handling

```typescript
// Try/catch pattern
try {
  const result = await api.createUser(userData)
  return result
} catch (error) {
  if (error instanceof ApiError) {
    // Handle specific error
    console.error('API Error:', error.message)
    throw error
  }
  // Handle unknown errors
  console.error('Unknown error:', error)
  throw new Error('Failed to create user')
}

// Async/await with error boundaries
async function fetchData() {
  try {
    return await api.getData()
  } catch (error) {
    logError(error)
    return null
  }
}
```

