
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
  members       Member[]
  invitations   Invitation[]

  @@unique([email])
  @@map("user")
  @@index([email])
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String
  createdAt            DateTime
  updatedAt            DateTime
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?

  @@unique([token])
  @@map("session")
  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
  @@index([userId])
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Organization {
  id          String       @id
  name        String
  slug        String?
  logo        String?
  createdAt   DateTime
  metadata    String?
  members     Member[]
  invitations Invitation[]
  forms       Form[]
  files       File[]
  folders     FileFolder[]
  reviewFlows ReviewFlow[]

  @@unique([slug])
  @@map("organization")
  @@index([name])
  @@index([slug])
}

enum MemberRole {
  owner
  admin
  reviewer
  executor
  member
}

model Member {
  id             String        @id
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           MemberRole
  createdAt      DateTime      @default(now())
  createdForms   Form[]        @relation("FormCreator")
  assignedForms  Form[]        @relation("FormExecutor")
  comments       Comment[]
  formHistory    FormHistory[]
  uploadedFiles  File[]        @relation("FileUploader")
  sharedFiles    FileShare[]
  createdFolders FileFolder[]
  lastModifiedBy String?
  version        Int           @default(1)

  @@map("member")
  @@index([organizationId])
  @@index([userId])
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String
  expiresAt      DateTime
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@map("invitation")
  @@index([organizationId])
  @@index([email])
}

enum FormStatus {
  DRAFT
  UNDER_REVIEW
  NEEDS_CHANGES
  APPROVED
  REJECTED
}

enum FieldType {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  SELECT
  CHECKBOX
  RADIO
  FILE
}

model Form {
  id               String        @id
  title            String
  description      String?
  status           FormStatus    @default(DRAFT)
  organizationId   String
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creatorMemberId  String
  creator          Member        @relation("FormCreator", fields: [creatorMemberId], references: [id])
  executorMemberId String?
  executor         Member?       @relation("FormExecutor", fields: [executorMemberId], references: [id])
  templateId       String?
  template         FormTemplate? @relation(fields: [templateId], references: [id])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  fields           FormField[]
  reviewFlow       ReviewFlow?
  history          FormHistory[]
  lastModifiedBy   String?
  version          Int           @default(1)

  @@index([organizationId, status])
  @@index([creatorMemberId])
  @@index([executorMemberId])
  @@map("form")
}

model FormField {
  id              String          @id
  formId          String
  form            Form            @relation(fields: [formId], references: [id], onDelete: Cascade)
  name            String
  type            FieldType
  value           String?
  required        Boolean         @default(false)
  validationRules String?
  order           Int
  options         String?
  files           FormFieldFile[]

  @@map("form_field")
  @@index([formId])
}

model FormTemplate {
  id             String              @id
  name           String
  description    String?
  fields         FormTemplateField[]
  forms          Form[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  lastModifiedBy String?
  version        Int                 @default(1)

  @@map("form_template")
}

model FormTemplateField {
  id           String       @id
  templateId   String
  template     FormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name         String
  type         FieldType
  validationRules String?
  defaultValue String?
  required     Boolean      @default(false)
  order        Int
  options      String?

  @@map("form_template_field")
  @@index([templateId])
}

model FormHistory {
  id        String     @id
  formId    String
  form      Form       @relation(fields: [formId], references: [id], onDelete: Cascade)
  status    FormStatus
  memberId  String
  member    Member     @relation(fields: [memberId], references: [id])
  data      String?
  createdAt DateTime   @default(now())

  @@map("form_history")
  @@index([formId])
  @@index([memberId])
}

enum ReviewFlowStatus {
  OPEN
  CLOSED
}

model ReviewFlow {
  id             String           @id
  formId         String           @unique
  form           Form             @relation(fields: [formId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  status         ReviewFlowStatus @default(OPEN)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  comments       Comment[]
  lastModifiedBy String?
  version        Int              @default(1)

  @@map("review_flow")
  @@index([organizationId])
  @@index([status])
}

model Comment {
  id             String     @id
  reviewFlowId   String
  reviewFlow     ReviewFlow @relation(fields: [reviewFlowId], references: [id], onDelete: Cascade)
  memberId       String
  member         Member     @relation(fields: [memberId], references: [id])
  content        String
  fieldReference String?
  createdAt      DateTime   @default(now())

  @@map("comment")
  @@index([reviewFlowId])
  @@index([memberId])
}

enum FileAccess {
  PRIVATE
  ORGANIZATION
  PUBLIC
}

model File {
  id               String          @id
  filename         String
  originalName     String
  path             String
  mimeType         String
  size             Int
  accessLevel      FileAccess      @default(ORGANIZATION)
  description      String?
  organizationId   String
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploaderMemberId String
  uploader         Member          @relation("FileUploader", fields: [uploaderMemberId], references: [id])
  folderId         String?
  folder           FileFolder?     @relation(fields: [folderId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  formFields       FormFieldFile[]
  sharedWith       FileShare[]
  accessedAt       DateTime?
  deleted          Boolean         @default(false)
  lastModifiedBy   String?
  version          Int             @default(1)

  @@map("file")
  @@index([organizationId])
  @@index([folderId])
  @@index([accessLevel])
}

model FileFolder {
  id              String       @id
  name            String
  description     String?
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creatorMemberId String
  creator         Member       @relation(fields: [creatorMemberId], references: [id])
  parentId        String?
  parent          FileFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children        FileFolder[] @relation("FolderHierarchy")
  files           File[]
  path            String?
  level           Int
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  lastModifiedBy  String?
  version         Int          @default(1)

  @@map("file_folder")
  @@index([organizationId])
  @@index([parentId])
  @@index([level])
}

model FileShare {
  id        String    @id
  fileId    String
  file      File      @relation(fields: [fileId], references: [id], onDelete: Cascade)
  memberId  String
  member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  @@map("file_share")
  @@index([fileId])
  @@index([memberId])
}

model FormFieldFile {
  id          String    @id
  formFieldId String
  formField   FormField @relation(fields: [formFieldId], references: [id], onDelete: Cascade)
  fileId      String
  file        File      @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@map("form_field_file")
  @@index([formFieldId])
  @@index([fileId])
}
